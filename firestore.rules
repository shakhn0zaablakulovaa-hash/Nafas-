rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "delanablackfyre@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'nickname', 'region']) &&
             data.uid is string &&
             data.role in ['user', 'admin'] &&
             data.nickname is string && data.nickname.size() <= 50 &&
             data.region is string && data.region.size() <= 50;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'content', 'category']) &&
             data.authorId is string &&
             data.content is string && data.content.size() < 2000 &&
             data.category in ['legal', 'psychological', 'support', 'success'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if (isAuthenticated() || userId.startsWith('sim_')) && isValidUser(request.resource.data);
      allow update: if (isAuthenticated() || userId.startsWith('sim_')) && isValidUser(request.resource.data);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if (isAuthenticated() || request.resource.data.authorId.startsWith('sim_')) && isValidPost(request.resource.data);
      allow update: if (isAuthenticated() || request.resource.data.authorId.startsWith('sim_')) && isValidPost(request.resource.data);
      
      match /replies/{replyId} {
        allow read: if true;
        allow create: if isAuthenticated() || request.resource.data.authorId.startsWith('sim_');
      }
    }
  }
}
